PORT=3001
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aio_presenter
DB_USER=postgres
DB_PASSWORD=your_password_here

# Railway lo inyecta automáticamente (tiene prioridad sobre las variables anteriores)
